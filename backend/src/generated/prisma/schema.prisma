// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Roles y permisos (RBAC en BD) ───

model Role {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  isSystem    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  authorities Authority[]
  users       User[]
}

model Authority {
  id         String @id @default(cuid())
  roleId     String
  permission String
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
}

// ─── Autenticación (múltiples métodos de login por usuario) ───

model Account {
  id           String   @id @default(cuid())
  userId       String
  provider     String // "credentials" | "google" | "saml" | etc.
  providerId   String // username para credentials; sub/email para oauth
  passwordHash String? // solo para provider "credentials"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

// ─── Entidades principales ───

model User {
  id                         String                      @id @default(cuid())
  name                       String
  roleId                     String
  role                       Role                        @relation(fields: [roleId], references: [id])
  accounts                   Account[]
  sessionVersion             Int                         @default(1)
  phone                      String?
  avatar                     String?
  status                     String                      @default("activo")
  joinedAt                   DateTime                    @default(now())
  lastActivity               DateTime?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  contactsAssigned           Contact[]
  opportunitiesAssigned      Opportunity[]
  companiesAssigned          Company[]
  activitiesAssigned         Activity[]
  campaignsCreated           Campaign[]
  crmFilesUploaded           CrmFile[]
  crmSalesGoal               CrmUserSalesGoal?
  crmUserMonthlySalesTargets CrmUserMonthlySalesTarget[]
  aiConversations            AiConversation[]
  aiKnowledgeBases           AiKnowledgeBase[]
  activityLogs               ActivityLog[]
  auditChangeSets            AuditChangeSet[]
}

// ─── Registro de actividad (auditoría general, no diff por campo) ───

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /**
   * Nombre del usuario en el momento del evento
   */
  userName    String
  action      String
  module      String
  entityType  String
  entityId    String?
  entityName  String?
  description String   @db.Text
  status      String   @default("exito")
  isCritical  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([module, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── Auditoría detallada (cambios campo a campo, agrupados por operación) ───

model AuditChangeSet {
  id         String             @id @default(cuid())
  userId     String?
  user       User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName   String
  action     String
  module     String
  entityType String
  entityId   String
  entityName String?
  createdAt  DateTime           @default(now())
  entries    AuditChangeEntry[]

  @@index([userId])
  @@index([entityType, entityId])
  @@index([module, createdAt])
  @@index([createdAt])
}

model AuditChangeEntry {
  id          String         @id @default(cuid())
  changeSetId String
  changeSet   AuditChangeSet @relation(fields: [changeSetId], references: [id], onDelete: Cascade)
  fieldKey    String
  fieldLabel  String
  oldValue    String         @db.Text
  newValue    String         @db.Text

  @@index([changeSetId])
}

// ─── Asistente IA (varios hilos por usuario) ───

model AiConversation {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  /**
   * Primer mensaje del usuario o "Nuevo chat".
   */
  title     String      @default("Nuevo chat")
  messages  AiMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId, updatedAt])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /**
   * user | assistant
   */
  role           String
  content        String         @db.Text
  /**
   * links/actions para mensajes del asistente
   */
  meta           Json?
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

// ─── Bases de conocimiento (RAG operativo por usuario) ───

model AiKnowledgeBase {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  /**
   * documentos | web | faq | tabular (UI Agentes IA)
   */
  type            String             @default("documentos")
  /**
   * text_only | upload | url | existing
   */
  sourceMode      String
  /**
   * Resumen / contenido pegado / notas (sin secretos de API)
   */
  description     String             @db.Text
  chunkSize       Int                @default(400)
  overlap         Int                @default(64)
  linkedAgentId   String?
  linkedAgentName String?
  /**
   * indexado | sync | error | pendiente
   */
  status          String             @default("pendiente")
  chunkCount      Int                @default(0)
  /**
   * Config estructurada (endpoint, método, ámbito CRM…); nunca guardar Bearer/API key en claro
   */
  sourceJson      Json?
  indexError      String?            @db.Text
  indexedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  chunks          AiKnowledgeChunk[]

  @@index([userId])
  @@index([userId, updatedAt])
}

model AiKnowledgeChunk {
  id              String                       @id @default(cuid())
  knowledgeBaseId String
  knowledgeBase   AiKnowledgeBase              @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  position        Int
  content         String                       @db.Text
  /// Embeddings pgvector (dimensión = migración SQL + OPENAI_EMBEDDING_DIMENSION). Rellenado por EmbeddingsService.
  embedding       Unsupported("vector(1536)")?
  createdAt       DateTime                     @default(now())

  @@index([knowledgeBaseId, position])
}

/**
 * Instrucciones editables del copiloto lateral (una fila, id = global).
 */
model AiAssistantInstruction {
  id                    String   @id
  instructionsChatTools String   @db.Text
  instructionsStream    String   @db.Text
  updatedByUserId       String?
  updatedAt             DateTime @updatedAt
}

// ─── Configuración CRM (singleton + catálogos + metas por usuario) ───

model CrmOrganizationProfile {
  id                  String                  @id @default("default")
  name                String                  @default("Taxi Monterrico")
  description         String                  @default("")
  contactEmail        String                  @default("")
  contactPhone        String                  @default("")
  address             String                  @default("")
  globalWeeklyGoal    Float                   @default(0)
  updatedAt           DateTime                @updatedAt
  monthlySalesTargets CrmMonthlySalesTarget[]
}

/**
 * Meta de facturación del equipo por mes calendario (UTC). Sin fila → meta 0 en reportes / dashboard.
 */
model CrmMonthlySalesTarget {
  id             String                 @id @default(cuid())
  organizationId String                 @default("default")
  periodStart    DateTime               @db.Date
  amount         Float                  @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   CrmOrganizationProfile @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodStart])
  @@index([organizationId, periodStart])
}

model CrmLeadSource {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      String
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
}

/**
 * Etapas del CRM (contactos, empresas, oportunidades): un solo catálogo por slug
 */
model CrmStage {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  color       String  @default("#64748b")
  probability Int     @default(0)
  enabled     Boolean @default(true)
  sortOrder   Int     @default(0)
  /**
   * Sembradas iniciales: no eliminar del catálogo si hay registros con esa etapa
   */
  isSystem    Boolean @default(false)
}

model CrmPriority {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  color       String
  description String  @default("")
  enabled     Boolean @default(true)
  sortOrder   Int     @default(0)
}

model CrmActivityType {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      String
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
}

model CrmUserSalesGoal {
  userId        String
  weeklyTarget  Float  @default(0)
  monthlyTarget Float  @default(0)
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId])
}

/**
 * Meta de ventas del asesor por mes calendario (UTC). Mes sin fila → meta 0 en reportes / tarjeta mensual.
 */
model CrmUserMonthlySalesTarget {
  id          String   @id @default(cuid())
  userId      String
  periodStart DateTime @db.Date
  amount      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
  @@index([userId, periodStart])
}

model Contact {
  id                String               @id @default(cuid())
  /**
   * Segmento de URL para /contactos/:slug (único; también se acepta :id cuid en API)
   */
  urlSlug           String               @unique
  name              String
  cargo             String?
  telefono          String
  correo            String
  fuente            String
  etapa             String               @default("lead")
  assignedTo        String?
  estimatedValue    Float                @default(0)
  docType           String?
  docNumber         String?
  departamento      String?
  provincia         String?
  distrito          String?
  direccion         String?
  clienteRecuperado String?
  etapaHistory      Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  user              User?                @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  companies         CompanyContact[]
  contacts          ContactContact[]     @relation("ContactLinks")
  linkedBy          ContactContact[]     @relation("LinkedContacts")
  opportunities     ContactOpportunity[]
  activities        ContactActivity[]

  @@index([assignedTo])
  @@index([etapa])
  @@index([assignedTo, etapa])
}

model Company {
  id                  String               @id @default(cuid())
  /**
   * Segmento de URL para /empresas/:slug
   */
  urlSlug             String               @unique
  name                String
  razonSocial         String?
  ruc                 String? // TODO: añadir @unique cuando se resuelvan RUC duplicados (ej: 20000000000)
  telefono            String?
  domain              String?
  rubro               String?
  tipo                String?
  linkedin            String?
  correo              String?
  distrito            String?
  provincia           String?
  departamento        String?
  direccion           String?
  /**
   * Facturación / ingreso estimado a nivel cuenta (sincronizado con contactos/oportunidades vinculadas)
   */
  facturacionEstimada Float                @default(0)
  fuente              String?
  clienteRecuperado   String?
  etapa               String               @default("lead")
  assignedTo          String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User?                @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  contacts            CompanyContact[]
  companies           CompanyCompany[]     @relation("CompanyLinks")
  linkedBy            CompanyCompany[]     @relation("LinkedCompanies")
  opportunities       CompanyOpportunity[]
  activities          CompanyActivity[]
  /**
   * Registro CRM “Cliente”: se crea al alcanzar etapa cierre_ganado (1:1 con empresa).
   */
  clientRecord        Client?

  @@index([assignedTo])
  @@index([etapa])
}

model Client {
  id        String   @id @default(cuid())
  companyId String   @unique
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /**
   * activo | inactivo | potencial
   */
  status    String   @default("activo")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Opportunity {
  id                String                   @id @default(cuid())
  urlSlug           String                   @unique
  title             String
  amount            Float
  probability       Int                      @default(0)
  etapa             String
  status            String                   @default("abierta")
  /**
   * baja | media | alta
   */
  priority          String                   @default("media")
  expectedCloseDate DateTime?
  assignedTo        String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  user              User?                    @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  contacts          ContactOpportunity[]
  companies         CompanyOpportunity[]
  opportunities     OpportunityOpportunity[] @relation("OpportunityLinks")
  linkedBy          OpportunityOpportunity[] @relation("LinkedOpportunities")
  activities        OpportunityActivity[]

  @@index([assignedTo])
  @@index([etapa])
  @@index([status])
  @@index([assignedTo, etapa])
  @@index([expectedCloseDate])
}

// ─── Activity: puede vincularse a muchos Contact, Company, Opportunity ───

model Activity {
  id            String                @id @default(cuid())
  type          String
  /**
   * Modalidad cuando type = tarea: llamada | reunion | correo | whatsapp
   */
  taskKind      String?
  title         String
  description   String
  assignedTo    String
  status        String                @default("pendiente")
  dueDate       DateTime
  startDate     DateTime?
  startTime     String?
  completedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [assignedTo], references: [id])
  contacts      ContactActivity[]
  companies     CompanyActivity[]
  opportunities OpportunityActivity[]

  @@index([assignedTo])
  @@index([dueDate])
  @@index([status])
  @@index([assignedTo, dueDate])
}

// ─── Tablas de unión entre entidades principales ───

model CompanyContact {
  id        String  @id @default(cuid())
  companyId String
  contactId String
  isPrimary Boolean @default(false)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([companyId, contactId])
}

model ContactContact {
  id        String  @id @default(cuid())
  contactId String
  linkedId  String
  contact   Contact @relation("ContactLinks", fields: [contactId], references: [id], onDelete: Cascade)
  linked    Contact @relation("LinkedContacts", fields: [linkedId], references: [id], onDelete: Cascade)

  @@unique([contactId, linkedId])
}

model ContactOpportunity {
  id            String      @id @default(cuid())
  contactId     String
  opportunityId String
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([contactId, opportunityId])
}

model CompanyCompany {
  id        String  @id @default(cuid())
  companyId String
  linkedId  String
  company   Company @relation("CompanyLinks", fields: [companyId], references: [id], onDelete: Cascade)
  linked    Company @relation("LinkedCompanies", fields: [linkedId], references: [id], onDelete: Cascade)

  @@unique([companyId, linkedId])
}

model CompanyOpportunity {
  id            String      @id @default(cuid())
  companyId     String
  opportunityId String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([companyId, opportunityId])
}

model OpportunityOpportunity {
  id            String      @id @default(cuid())
  opportunityId String
  linkedId      String
  opportunity   Opportunity @relation("OpportunityLinks", fields: [opportunityId], references: [id], onDelete: Cascade)
  linked        Opportunity @relation("LinkedOpportunities", fields: [linkedId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, linkedId])
}

// ─── Tablas de unión de Activity con Contact, Company, Opportunity ───

model ContactActivity {
  id         String   @id @default(cuid())
  contactId  String
  activityId String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([contactId, activityId])
}

model CompanyActivity {
  id         String   @id @default(cuid())
  companyId  String
  activityId String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([companyId, activityId])
}

model OpportunityActivity {
  id            String      @id @default(cuid())
  opportunityId String
  activityId    String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  activity      Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, activityId])
}

// Envíos de campaña por SMTP: historial para límite anti-spam por destinatario / hora
model CampaignEmailSendLog {
  id      String   @id @default(cuid())
  toEmail String
  sentAt  DateTime @default(now())

  @@index([toEmail, sentAt])
}

// Campaña de mensajería masiva persistida (CRM)
model Campaign {
  id                String    @id @default(cuid())
  name              String
  status            String
  channel           String
  /**
   * Contenido completo solo en borrador; en `sent` suele ser mínimo o null
   */
  messageJson       Json?
  recipientsJson    Json?
  /**
   * Asunto guardado para campañas enviadas (sin cuerpo en BD)
   */
  subjectSnapshot   String?
  resultsJson       Json?
  recipientCount    Int       @default(0)
  sentCount         Int       @default(0)
  deliveredCount    Int       @default(0)
  openedCount       Int       @default(0)
  clickedCount      Int       @default(0)
  failedCount       Int       @default(0)
  bounceCount       Int       @default(0)
  relatedContactIds String[]  @default([])
  createdAt         DateTime  @default(now())
  sentAt            DateTime?
  createdById       String
  createdByName     String
  createdBy         User      @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([createdById])
  @@index([createdAt])
}

/**
 * Adjuntos del CRM: metadatos en BD; binario en S3/MinIO o URL pública (CDN) vía proxy de medios.
 */
model CrmFile {
  id                String   @id @default(cuid())
  /**
   * Clave S3 o URL https del CDN si la subida fue por MEDIA_UPLOAD_URL.
   */
  storageKey        String   @unique
  originalName      String
  mimeType          String
  size              Int
  /**
   * contact | company | opportunity | activity | email | task
   */
  entityType        String
  entityId          String
  entityName        String?
  relatedEntityType String?
  relatedEntityId   String?
  relatedEntityName String?
  uploadedBy        String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
  @@index([uploadedBy])
  @@index([createdAt])
}
