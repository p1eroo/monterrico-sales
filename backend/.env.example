DATABASE_URL="postgresql://user:pass@localhost:5432/db"
JWT_SECRET="change-me"

# SMTP (envío de campañas por correo)
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=marketing@ejemplo.com
SMTP_PASS="tu-contraseña"

# Anti-spam envío masivo (opcional; por defecto 2–5 s entre correos, máx. 100/h por destinatario)
# CAMPAIGN_EMAIL_DELAY_MIN_MS=2000
# CAMPAIGN_EMAIL_DELAY_MAX_MS=5000
# CAMPAIGN_EMAIL_MAX_PER_RECIPIENT_HOUR=100

# Adjuntos CRM: proxy de medios (prioridad si están definidos) o MinIO/S3 directo.
# MEDIA_UPLOAD_URL=https://cloud.3w.pe/media
# MEDIA_BUCKET=crm-adjuntos
# Bucket para avatares (mismo proxy; debe existir en MinIO/media).
# MEDIA_AVATAR_BUCKET=crm-avatar
# (El nombre debe ser el que acepte el servicio /media; no tiene por qué coincidir con S3_BUCKET.)
# Reenviar Authorization del usuario al subir (por defecto true). O fija token de servicio:
# MEDIA_FORWARD_USER_AUTH=true
# MEDIA_UPLOAD_AUTHORIZATION=Bearer ...

# MinIO / S3 (solo si no usas MEDIA_*)
# S3_ENDPOINT=https://minio.tu-dominio.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=crm-adjuntos
# S3_FORCE_PATH_STYLE=true
# FILES_MAX_MB=50
# FILES_PRESIGN_TTL_SEC=3600
