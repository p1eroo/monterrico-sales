DATABASE_URL="postgresql://user:pass@localhost:5432/db"
JWT_SECRET="change-me"

# Asistente AI (opcional). Sin clave, el endpoint usa respuestas locales inteligentes.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=2048
# Embeddings RAG (misma OPENAI_API_KEY; requiere pgvector en PostgreSQL y migración vector(1536)).
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Debe coincidir con la columna en prisma/migrations/*_ai_knowledge_chunk_embedding/migration.sql
# OPENAI_EMBEDDING_DIMENSION=1536
# Backfill embeddings (npm run kb:backfill-embeddings): chunks con embedding NULL en bases indexado
# KB_BACKFILL_MAX=2000
# KB_BACKFILL_FETCH=120
# KB_BACKFILL_DELAY_MS=250
# Logs: el servicio AI escribe JSON en consola (event ai.openai.*) para duración y errores HTTP.
# Streaming: POST /api/ai/chat/stream (SSE, sin tools). El front usa VITE_AI_CHAT_STREAM=true.
# Retención: borra mensajes del asistente más antiguos que N días (por conversación), tras cada respuesta.
# AI_CHAT_RETENTION_DAYS=90

# SMTP (envío de campañas por correo)
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=marketing@ejemplo.com
SMTP_PASS="tu-contraseña"

# Anti-spam envío masivo (opcional; por defecto 2–5 s entre correos, máx. 100/h por destinatario)
# CAMPAIGN_EMAIL_DELAY_MIN_MS=2000
# CAMPAIGN_EMAIL_DELAY_MAX_MS=5000
# CAMPAIGN_EMAIL_MAX_PER_RECIPIENT_HOUR=100

# Adjuntos CRM: proxy de medios (prioridad si están definidos) o MinIO/S3 directo.
# MEDIA_UPLOAD_URL=https://cloud.3w.pe/media
# MEDIA_BUCKET=crm-adjuntos
# Bucket para avatares (mismo proxy; debe existir en MinIO/media).
# MEDIA_AVATAR_BUCKET=crm-avatar
# (El nombre debe ser el que acepte el servicio /media; no tiene por qué coincidir con S3_BUCKET.)
# Reenviar Authorization del usuario al subir (por defecto true). O fija token de servicio:
# MEDIA_FORWARD_USER_AUTH=true
# MEDIA_UPLOAD_AUTHORIZATION=Bearer ...

# MinIO / S3 (solo si no usas MEDIA_*)
# S3_ENDPOINT=https://minio.tu-dominio.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=crm-adjuntos
# S3_FORCE_PATH_STYLE=true
# FILES_MAX_MB=50
# FILES_PRESIGN_TTL_SEC=3600
