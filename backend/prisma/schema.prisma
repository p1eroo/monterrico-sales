// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Roles y permisos (RBAC en BD) ───

model Role {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorities Authority[]
  users       User[]
}

model Authority {
  id         String   @id @default(cuid())
  roleId     String
  permission String
  role       Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@unique([roleId, permission])
}

// ─── Autenticación (múltiples métodos de login por usuario) ───

model Account {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // "credentials" | "google" | "saml" | etc.
  providerId   String   // username para credentials; sub/email para oauth
  passwordHash String?  // solo para provider "credentials"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerId])
}

// ─── Entidades principales ───

model User {
  id            String    @id @default(cuid())
  name          String
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  accounts      Account[]
  phone         String?
  avatar        String?
  status        String    @default("activo")
  joinedAt      DateTime  @default(now())
  lastActivity  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  contactsAssigned     Contact[]
  opportunitiesAssigned Opportunity[]
  companiesAssigned    Company[]
  activitiesAssigned   Activity[]
}

model Contact {
  id                 String    @id @default(cuid())
  name               String
  cargo              String?
  telefono           String
  correo             String
  fuente             String
  etapa              String    @default("lead")
  assignedTo         String?
  estimatedValue     Float     @default(0)
  nextAction         String?
  nextFollowUp       DateTime?
  notes              String?
  tags               String[]  @default([])
  docType            String?
  docNumber          String?
  departamento       String?
  provincia          String?
  distrito           String?
  direccion          String?
  clienteRecuperado  String?
  etapaHistory       Json?
  createdAt          DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user               User?     @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  companies          CompanyContact[]
  contacts           ContactContact[]  @relation("ContactLinks")
  linkedBy           ContactContact[]  @relation("LinkedContacts")
  opportunities      ContactOpportunity[]
  activities         ContactActivity[]

  @@index([assignedTo])
  @@index([etapa])
  @@index([assignedTo, etapa])
}

model Company {
  id           String   @id @default(cuid())
  name         String
  razonSocial  String?
  ruc          String?  // TODO: añadir @unique cuando se resuelvan RUC duplicados (ej: 20000000000)
  telefono    String?
  domain       String?
  rubro       String?
  tipo        String?
  linkedin    String?
  correo      String?
  distrito    String?
  provincia   String?
  departamento String?
  direccion   String?
  /** Facturación / ingreso estimado a nivel cuenta (sincronizado con contactos/oportunidades vinculadas) */
  facturacionEstimada Float    @default(0)
  fuente              String?
  clienteRecuperado   String?
  etapa               String    @default("lead")
  assignedTo          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?     @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  contacts     CompanyContact[]
  companies    CompanyCompany[]  @relation("CompanyLinks")
  linkedBy     CompanyCompany[]  @relation("LinkedCompanies")
  opportunities CompanyOpportunity[]
  activities   CompanyActivity[]

  @@index([assignedTo])
  @@index([etapa])
}

model Opportunity {
  id                String    @id @default(cuid())
  title             String
  amount            Float
  fuente            String?
  probability       Int       @default(0)
  etapa             String
  status            String    @default("abierta")
  /** baja | media | alta */
  priority          String    @default("media")
  expectedCloseDate DateTime?
  assignedTo        String?
  createdAt         DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user              User?     @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  contacts          ContactOpportunity[]
  companies         CompanyOpportunity[]
  opportunities     OpportunityOpportunity[]  @relation("OpportunityLinks")
  linkedBy          OpportunityOpportunity[]  @relation("LinkedOpportunities")
  activities        OpportunityActivity[]

  @@index([assignedTo])
  @@index([etapa])
  @@index([status])
  @@index([assignedTo, etapa])
  @@index([expectedCloseDate])
}

// ─── Activity: puede vincularse a muchos Contact, Company, Opportunity ───

model Activity {
  id            String    @id @default(cuid())
  type          String
  title         String
  description   String
  assignedTo    String
  status        String    @default("pendiente")
  dueDate       DateTime
  startDate     DateTime?
  startTime     String?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [assignedTo], references: [id])
  contacts      ContactActivity[]
  companies     CompanyActivity[]
  opportunities OpportunityActivity[]

  @@index([assignedTo])
  @@index([dueDate])
  @@index([status])
  @@index([assignedTo, dueDate])
}

// ─── Tablas de unión entre entidades principales ───

model CompanyContact {
  id         String   @id @default(cuid())
  companyId  String
  contactId  String
  isPrimary  Boolean  @default(false)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  @@unique([companyId, contactId])
}

model ContactContact {
  id        String   @id @default(cuid())
  contactId String
  linkedId  String
  contact   Contact  @relation("ContactLinks", fields: [contactId], references: [id], onDelete: Cascade)
  linked    Contact  @relation("LinkedContacts", fields: [linkedId], references: [id], onDelete: Cascade)
  @@unique([contactId, linkedId])
}

model ContactOpportunity {
  id             String      @id @default(cuid())
  contactId      String
  opportunityId  String
  contact        Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  @@unique([contactId, opportunityId])
}

model CompanyCompany {
  id        String   @id @default(cuid())
  companyId String
  linkedId  String
  company   Company  @relation("CompanyLinks", fields: [companyId], references: [id], onDelete: Cascade)
  linked    Company  @relation("LinkedCompanies", fields: [linkedId], references: [id], onDelete: Cascade)
  @@unique([companyId, linkedId])
}

model CompanyOpportunity {
  id             String      @id @default(cuid())
  companyId      String
  opportunityId  String
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  @@unique([companyId, opportunityId])
}

model OpportunityOpportunity {
  id             String      @id @default(cuid())
  opportunityId  String
  linkedId       String
  opportunity    Opportunity @relation("OpportunityLinks", fields: [opportunityId], references: [id], onDelete: Cascade)
  linked         Opportunity @relation("LinkedOpportunities", fields: [linkedId], references: [id], onDelete: Cascade)
  @@unique([opportunityId, linkedId])
}

// ─── Tablas de unión de Activity con Contact, Company, Opportunity ───

model ContactActivity {
  id         String   @id @default(cuid())
  contactId  String
  activityId String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  @@unique([contactId, activityId])
}

model CompanyActivity {
  id         String   @id @default(cuid())
  companyId  String
  activityId String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  @@unique([companyId, activityId])
}

model OpportunityActivity {
  id             String      @id @default(cuid())
  opportunityId  String
  activityId     String
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  activity       Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  @@unique([opportunityId, activityId])
}